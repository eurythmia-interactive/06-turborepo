generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProviderType {
  LOCAL
  GITHUB
  GOOGLE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
  GUEST
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String?
  image          String?
  status         UserStatus  @default(PENDING)
  role           Role        @default(MEMBER)
  customRoleId   String?
  isSystem       Boolean     @default(false)
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  providers           AuthenticationProvider[]
  sessions            RefreshToken[]
  tenants             UserTenant[]
  auditLogs           AuditLog[]
  systemConfigs       SystemConfig[]
  featureFlags        FeatureFlag[]
  apiKeys             ApiKey[]
  invitations         UserInvitation[]       @relation("InvitedBy")
  passwordResetTokens PasswordResetToken[]
  customRole          CustomRole?            @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  plan      String    @default("free")
  domain    String?
  suspended Boolean   @default(false)
  isSystem  Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users        UserTenant[]
  auditLogs    AuditLog[]
  featureFlags FeatureFlag[]
  apiKeys      ApiKey[]
  invitations  UserInvitation[]
}

model UserTenant {
  userId       String
  tenantId     String
  role         Role      @default(MEMBER)
  customRoleId String?
  createdAt    DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@id([userId, tenantId])
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  userTenants UserTenant[]
}

model AuthenticationProvider {
  id             String           @id @default(cuid())
  userId         String
  type           AuthProviderType
  providerUserId String
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, providerUserId])
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  familyId     String
  replacedById String?   @unique
  revoked      Boolean   @default(false)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken? @relation("ReplacedBy", fields: [replacedById], references: [id])
  replaces   RefreshToken? @relation("ReplacedBy")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  action    String
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  updatedByUser User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  tenantId    String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  tenant        Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  updatedByUser User?   @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  tenantId   String?
  userId     String?
  permissions String[]
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revoked    Boolean   @default(false)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model UserInvitation {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  tenantId   String?
  role       Role
  invitedBy  String
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  invitedByUser User @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
