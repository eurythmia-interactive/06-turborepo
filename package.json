{
  "name": "06-turborepo",
  "version": "0.1.0",
  "private": true,
  "description": "Polyglot-ready monorepo: Next.js + NestJS + Prisma + Turborepo",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0 <27.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:ox": "oxlint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "turbo run db:generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxlint": "1.70.0",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "@eslint/js": "10.0.1",
    "eslint": "9.39.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
