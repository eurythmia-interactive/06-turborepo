# Database
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=app_dev
DATABASE_URL=postgresql://dev:dev@localhost:5432/app_dev

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars-long
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRES_IN_ACCESS=15m
JWT_EXPIRES_IN_REFRESH=7d
JWT_ISSUER=turborepo-api
JWT_AUDIENCE=turborepo-client

# Cookies
COOKIE_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
